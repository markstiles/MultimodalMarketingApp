# Database
POSTGRES_URL="postgresql://user:password@localhost:5432/xm_chatbot?schema=public"
POSTGRES_PRISMA_URL="postgresql://user:password@localhost:5432/xm_chatbot?schema=public&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@localhost:5432/xm_chatbot?schema=public"
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"
PRISMA_LOG_LEVEL="warn"

# OpenAI
OPENAI_API_KEY="sk-..."

# MCP Server (Sitecore Search)
MCP_SERVER_URL="ws://localhost:3001"  # Railway URL in production

# Sitecore (for MCP server)
SITECORE_DOMAIN_ID="12345678"
SITECORE_CLIENT_KEY="123456789-12345678"
SITECORE_API_KEY="01-xxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SITECORE_RFK_ID="rfkid_7"

# Marketer MCP (with OAuth)
MARKETER_MCP_URL="https://edge-platform.sitecorecloud.io/mcp/marketer-mcp-prod"

# Edge Platform Proxy (override for the library to use the Edge Platform Proxy)
EDGE_PLATFORM_PROXY_URL="https://edge-platform.sitecorecloud.io/stream/ai-agent-api"

# Sitecore Agent API
SITECORE_AGENT_API_AUDIENCE="https://edge-platform.sitecorecloud.io"
# deploy automation credentials
SITECORE_AGENT_API_CLIENT_ID="your-client-id"
SITECORE_AGENT_API_CLIENT_SECRET="your-client-secret"

# app credentials
OAUTH_CLIENT_ID="your-client-id"
OAUTH_CLIENT_SECRET="your-client-secret"
OAUTH_AUTHORIZATION_URL="https://edge-platform.sitecorecloud.io/mcp/authorize"
OAUTH_TOKEN_URL="https://edge-platform.sitecorecloud.io/mcp/token"
OAUTH_SCOPE="openid profile email mcp:read mcp:write"
OAUTH_AUDIENCE="https://edge-platform.sitecorecloud.io/mcp/marketer-mcp-prod"
# Use dynamic registration against /mcp/register (recommended for localhost/dev).
# If set to "false", the code will use OAUTH_CLIENT_ID/OAUTH_CLIENT_SECRET as-is.
OAUTH_DYNAMIC_REGISTRATION="true"

# If your App Studio config requires an exact callback URL, pin it here.
OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# Next.js
NEXT_PUBLIC_VERCEL_URL="localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Asset URL construction (optional)
# Environment-specific host segment used with Edge to build asset URLs:
# https://<ENVIRONMENT_HOST>.sitecorecloud.io/sitecore/shell/Applications/-/media/<asset_item_id>.ashx
ENVIRONMENT_HOST=""
NEXT_PUBLIC_ENVIRONMENT_HOST=""

