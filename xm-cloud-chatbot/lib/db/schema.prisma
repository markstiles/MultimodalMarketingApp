// Prisma schema for XM Cloud Chatbot

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model Conversation {
  id            String   @id @default(cuid())
  userId        String
  siteId        String
  assistantType String   // content_auditor, campaign_designer, seo_optimizer, content_authoring
  title         String?  // Auto-generated after 2nd message
  metadata      Json?    // Additional context (page names, tags, etc.)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  messages      Message[]
  analytics     Analytics[]
  
  @@index([userId, siteId])
  @@index([siteId])
  @@index([createdAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user, assistant, system
  content        String   @db.Text
  images         String[] // Array of image URLs (for generated images)
  currentPageId  String?  // Page context when message was sent
  tokens         Int?     // Token count for this message
  mcpCalls       Json?    // Array of MCP tool calls made
  latencyMs      Int?     // Response latency in milliseconds
  timestamp      DateTime @default(now())
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@index([timestamp])
}

model Analytics {
  id             String   @id @default(cuid())
  conversationId String
  eventType      EventType
  eventData      Json     // Flexible data storage for different event types
  timestamp      DateTime @default(now())
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@index([eventType])
  @@index([timestamp])
}

enum EventType {
  token_usage
  mcp_call
  content_accepted
  content_rejected
  assistant_switch
}

model oAuthToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime
  scope        String?
  tokenType    String   @default("Bearer")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([userId])
  @@index([expiresAt])
}
