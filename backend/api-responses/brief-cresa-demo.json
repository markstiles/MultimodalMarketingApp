    "Objectives": {
      "type": "RichText",
      "value": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "The primary objective of this campaign is to build awareness and generate excitement about the launch of Cresa's new office in Santa Fe, New Mexico. The campaign seeks to increase visibility within the local market, establish Cresa as a trusted partner for corporate real estate solutions, and create meaningful community engagement. Success will be measured through heightened brand presence in Santa Fe, attendance at launch activities, and initial inquiries or partnerships stemming from the campaign."
              }
            ]
          }
        ]
      }
    },
