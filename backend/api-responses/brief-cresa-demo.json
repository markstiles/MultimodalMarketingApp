    "Message": {
      "type": "RichText",
      "value": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Cresa's new Santa Fe office is here to empower local businesses with expert corporate real estate solutions tailored to their growth and success. By championing transparency, collaboration, and forward-thinking strategies, we bring a fresh and insightful approach to the local market. Together, let's shape the future of work environments in Santa Fe."
              }
            ]
          }
        ]
      }
