{
	"servers": {
		"marketer-mcp": {
			"url": "https://edge-platform.sitecorecloud.io/mcp/marketer-mcp-prod",
            "auth": {
                "type": "external"
            }
		},
        "sitecore": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@antonytm/mcp-sitecore-server@1.3.5"
			],
			"env": {
				"TRANSPORT": "stdio",
				"GRAPHQL_ENDPOINT": "${input:graphql_endpoint}",
				"GRAPHQL_SCHEMAS": "${input:graphql_schemas}",
				"GRAPHQL_API_KEY": "${input:graphql_api_key}",
				"GRAPHQL_HEADERS": "",
				"ITEM_SERVICE_DOMAIN": "sitecore",
				"ITEM_SERVICE_USERNAME": "${input:item_service_username}",
				"ITEM_SERVICE_PASSWORD": "${input:item_service_password}",
				"ITEM_SERVICE_SERVER_URL": "${input:item_service_server_url}",
				"NODE_TLS_REJECT_UNAUTHORIZED": "0"
			}
		},
	},
	"inputs": [
		{
			"id": "graphql_endpoint",
			"type": "promptString",
			"description": "GraphQL endpoint URL"
		},
		{
			"id": "graphql_schemas",
			"type": "promptString",
			"description": "GraphQL schemas (comma-separated)"
		},
		{
			"id": "graphql_api_key",
			"type": "promptString",
			"description": "GraphQL API key (GUID or blank)"
		},
		{
			"id": "item_service_username",
			"type": "promptString",
			"description": "Item Service username"
		},
		{
			"id": "item_service_password",
			"type": "promptString",
			"description": "Item Service password"
		},
		{
			"id": "item_service_server_url",
			"type": "promptString",
			"description": "Item Service server URL"
		},
		{
			"id": "oauth_client_id",
			"type": "promptString",
			"description": "OAuth Client ID"
		},
		{
			"id": "oauth_client_secret",
			"type": "promptString",
			"description": "OAuth Client Secret"
		},
		{
			"id": "oauth_token_url",
			"type": "promptString",
			"description": "OAuth Token URL"
		}
	]
}