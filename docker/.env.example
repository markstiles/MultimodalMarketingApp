# Docker container credentials — used by docker-compose.yml only.
# Copy this file to docker/.env before running `just dev` or `docker compose up`.
# These values must match the DATABASE_URL in the root .env file.

# PostgreSQL superuser username
POSTGRES_USER=postgres

# PostgreSQL superuser password
POSTGRES_PASSWORD=postgres

# PostgreSQL database name (must match the database name in DATABASE_URL)
POSTGRES_DB=marketing_app
