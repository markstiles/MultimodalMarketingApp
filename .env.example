# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT CONFIGURATION
# Copy this file to .env and fill in all SECRET values before running `just dev`
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
# SECRET: requires a real value — startup will refuse if missing
LLM_API_KEY=

# DEFAULT: safe for local dev
LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=   # Optional: override for alternative providers (e.g., Azure, Ollama)

# Cohere API Key
COHERE_API_KEY=

# Tavily API Key
TAVILY_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# DEFAULT: matches docker/docker-compose.yml service defaults
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketing_app

# ── Runtime Context ───────────────────────────────────────────────────────────
# DEFAULT: disables Sitecore OAuth and iframe context for local development
RUNTIME_CONTEXT=local

# DEFAULT: stub Sitecore context values — used when RUNTIME_CONTEXT=local
LOCAL_PAGE_ID=stub-page-id
LOCAL_SITE_ID=stub-site-id
LOCAL_LANGUAGE=en

# ── Service URLs ──────────────────────────────────────────────────────────────
# DEFAULT: Next.js proxies to the local FastAPI instance
API_URL=http://localhost:8000

# ── Frontend public vars (exposed to the browser) ────────────────────────────
NEXT_PUBLIC_RUNTIME_CONTEXT=local
NEXT_PUBLIC_LOCAL_PAGE_ID=stub-page-id
NEXT_PUBLIC_LOCAL_SITE_ID=stub-site-id
NEXT_PUBLIC_LOCAL_LANGUAGE=en

# ── Sitecore Marketer MCP ────────────────────────────────────────────────────
# Required for Marketer MCP tool access (OAuth2 client credentials)
AUTHOR_APP_ID=
AUTHOR_APP_CLIENT_CREDENTIALS=

# SitecoreAI Automation Keys
SITECORE_CLIENT_ID_AUTOMATION=
SITECORE_CLIENT_SECRET_AUTOMATION=

# Sitecore Content Management Host
SITECORE_CM_HOST=https://<environment-id>.sitecorecloud.io

# Sitecore Agent REST API (asset uploads and direct REST operations)
SITECORE_AGENTS_API_BASE_URL=https://edge-platform.sitecorecloud.io/stream/ai-agent-api

# Sitecore Stream organization ID — required for Brand Management, Document Management,
# and Brand Review APIs. Found in the Sitecore Cloud Portal under Organization Settings.
SITECORE_ORGANIZATION_ID=

# Sitecore Pages API
SITECORE_PAGES_API_BASE_URL=https://xmapps-api.sitecorecloud.io/api/v1/pages

# Sitecore Sites API — used to resolve site name and collection (organization grouping)
# from a site_id. Collection is used as the top-level folder in media library paths.
# Optional override; defaults to the standard XM Cloud Sites API endpoint.
# SITECORE_SITES_API_BASE_URL=https://xmapps-api.sitecorecloud.io/api/v1/sites

# Optional overrides (defaults shown)
# MARKETER_MCP_URL=https://edge-platform.sitecorecloud.io/mcp/marketer-mcp-prod
# MARKETER_MCP_TOKEN_URL=https://auth.sitecorecloud.io/oauth/token
# MARKETER_MCP_AUDIENCE=https://api.sitecorecloud.io

# ── Sitecore Documentation MCP ───────────────────────────────────────────────
# No authentication required — always enabled at startup
# SITECORE_DOCS_MCP_URL=https://sitecore.mcp.kapa.ai   # optional override

# ── MLflow ────────────────────────────────────────────────────────────────────
# DEFAULT: write traces to local MLflow server; open http://localhost:5000 to view
MLFLOW_TRACKING_URI=http://localhost:5000
